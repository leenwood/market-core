DATABASE_DSN=postgres://market:market@localhost:5432/market_core?sslmode=disable
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_PPROF_ENABLED=false
LOG_LEVEL=info
LOG_FORMAT=json
MIGRATION_DIR=migrations
OTEL_ENABLED=false
OTEL_EXPORTER=stdout
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=market-core
APP_ENV=production
